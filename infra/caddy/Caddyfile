# Tracked in-repo so Caddy config changes are diffable/reviewable like any
# other code change. On the server, /srv/homelab/caddy/Caddyfile is a symlink
# to this file — editing it here *is* editing the live config, but Caddy
# still needs an explicit reload (see ../scripts/reload-caddy.sh); it does
# not hot-watch this file.
{
	auto_https off
}

http://rinchen.co {
	reverse_proxy localhost:3001
	encode gzip
}

# admin.rinchen.co reverse-proxies to the exact same origin as rinchen.co —
# sites/personal/nginx.conf does the actual host-based routing to the private
# `admin` service vs. the public site. Nothing admin-specific happens here.
http://admin.rinchen.co {
	reverse_proxy localhost:3001
}

# Bodhicharya Foundation — independent site (sites/bodhicharya), no
# connection to rinchen.co: separate container, separate port, separate
# domain. Both apex and www are covered here so DNS can point either at
# this origin.
http://bodhicharyafoundation.org, http://www.bodhicharyafoundation.org {
	reverse_proxy localhost:3002
	encode gzip
}

# Tap Tunes — sites/tap-tunes, independent site, subdomain of rinchen.co
# (no purchased domain needed yet; swap to a dedicated domain later the same
# way as any other site — infra/register-site.sh + a DNS change).
#
# SECURITY NOTE before real payments go live here: this still matches the
# rest of the fleet's Cloudflare SSL "Flexible" + `auto_https off` (browser
# <-> Cloudflare is encrypted, Cloudflare <-> this origin is plaintext over
# the WAN). Because this site handles Stripe webhooks and payment flows,
# harden this before accepting live traffic — but note Server-Dev-chat.md's
# "Learnings" #2: Let's Encrypt HTTP-01 has been unreliable on this Verizon
# connection, which is *why* the fleet runs Flexible today. So prefer a
# **Cloudflare Tunnel** (cloudflared, outbound-only, no port-forward or ACME
# needed) over "Full (strict) + Let's Encrypt origin cert" for this site —
# already an open TODO in Server-Dev-chat.md. That's a Cloudflare-dashboard +
# on-server change, not something this file alone can do.
http://taptunes.rinchen.co {
	reverse_proxy localhost:3003
	encode gzip
}

http:// {
	respond "Homelab server is running." 200
}
